#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

# Vet
echo "  Vetting..."
go vet ./...

# Lint
echo "  Linting..."
if ! command -v golangci-lint &>/dev/null; then
  echo "Error: golangci-lint is not installed. See https://golangci-lint.run/usage/install/"
  exit 1
fi
golangci-lint run ./...

# Test
echo "  Testing..."
go test -race ./...

echo "All pre-commit checks passed."
